<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile Settings - AI Character Chat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="public/config.js"></script>
    <link rel="stylesheet" href="public/styles.css?v=15">
</head>

<body class="has-navbar"
    x-data="{ ...userProfileApp(), prefix: window.APP_CONFIG?.appPrefix || '' }" x-init="checkAuth().then(authenticated => { if (authenticated) loadProfile(); })"
    x-cloak>

    <div class="wrapper">
    <nav class="navbar navbar-expand-lg navbar-cyber">
        <div class="container-fluid">
            <a class="navbar-brand navbar-brand-cyber" :href="prefix + '/chat'">AI Character Chat</a>
            <button type="button" id="chat-sidebar-toggle" class="d-lg-none btn btn-outline-info me-2"
                @click="sidebarActive = !sidebarActive">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi-list"
                    viewBox="0 0 16 16">
                    <path fill-rule="evenodd"
                        d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z" />
                </svg>
            </button>
            <div class="navbar-collapse" id="navbarNav">
                <div class="dropdown">
                    <div class="user-nav-summary dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown"
                        aria-expanded="false">
                        <div class="profile-avatar-sm"
                            x-text="user.display_name ? user.display_name[0].toUpperCase() : 'U'"></div>
                        <span>Menu</span>
                    </div>

                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-cyber" aria-labelledby="userDropdown">
                        <li class="nav-item">
                            <a class="nav-link nav-link-cyber" :href="prefix + '/chat'">Chat</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-cyber" :href="prefix + '/characters'">Characters</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-cyber" :href="prefix + '/image-gen'">Image Gen</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-cyber active" :href="prefix + '/profile'">Profile Settings</a>
                        </li>
                        <li>
                            <hr class="dropdown-divider border-secondary">
                        </li>
                        <li><a class="dropdown-item dropdown-item-cyber text-danger" href="#"
                                @click.prevent="logout()">Logout</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card card-cyber">
                    <div class="card-header card-header-cyber">
                        <h4 class="mb-0">Profile Settings</h4>
                    </div>
                    <div class="card-body">
                        <form @submit.prevent="updateProfile()">
                            <div class="mb-3">
                                <label class="form-label text-dim">Email</label>
                                <input type="email" x-model="profileForm.email" class="form-control" required>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label text-dim">Display Name</label>
                                <input type="text" x-model="profileForm.display_name" class="form-control" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-dim">About You (optional)</label>
                                <textarea x-model="profileForm.about" class="form-control" rows="4" 
                                    placeholder="Tell us about yourself... This information helps AI characters better understand and interact with you."></textarea>
                                <small class="text-muted">This information will be used by AI characters to personalize their responses</small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-dim">New Password (optional)</label>
                                <input type="password" x-model="profileForm.password" class="form-control"
                                    placeholder="Enter new password">
                                <small class="text-muted">Leave blank to keep current password</small>
                            </div>

                            <div x-show="profileMessage"
                                :class="profileMessage?.type === 'error' ? 'alert alert-danger' : 'alert alert-success'"
                                x-text="profileMessage?.text" class="py-2 small"></div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-cyber" :disabled="profileLoading">
                                    <span x-show="!profileLoading">Save Changes</span>
                                    <span x-show="profileLoading">Processing...</span>
                                </button>
                                <a :href="prefix + '/chat'" class="btn btn-outline-secondary">Back to Chat</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="public/app_userprofile.js?v=4"></script>
</body>
</html>
