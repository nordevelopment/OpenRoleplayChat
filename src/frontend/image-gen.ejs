<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="public/config.js"></script>
    <link rel="stylesheet" href="public/styles.css?v=15">
    <!-- custom styles for generator -->
    <style>
        .image-preview-container {
            border: 2px dashed var(--border-color);
            background: rgba(0, 0, 0, 0.2);
            min-height: 400px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .image-preview-container img {
            max-width: 100%;
            max-height: 800px;
            object-fit: contain;
            border-radius: 6px;
            z-index: 2;
        }

        .loading-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.7);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }

        .image-settings-panel {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 20px;
        }

        .provider-selector .btn-group .btn {
            border-radius: 8px;
            transition: all 0.3s ease;
            border: 1px solid var(--accent-teal);
        }

        .provider-selector .btn-group .btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(56, 140, 129, 0.3);
        }

        .setting-card {
            background: rgba(16, 41, 53, 0.4);
            border: 1px solid rgba(56, 140, 129, 0.2);
            border-radius: 8px;
            padding: 12px;
            transition: var(--transition-smooth);
        }

        .setting-card:hover {
            border-color: var(--accent-teal);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(56, 140, 129, 0.2);
        }

        .prompt-container {
            position: relative;
        }

        .prompt-preview {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(56, 140, 129, 0.2);
            border-radius: 6px;
            padding: 8px;
            margin-top: 8px;
            font-size: 0.9rem;
            max-height: 60px;
            overflow-y: auto;
        }

        .preview-text {
            color: var(--text-dim);
            line-height: 1.4;
        }

        .history-grid-modern {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 12px;
        }

        .history-item {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.2s ease;
            border: 1px solid var(--border-color);
            background: var(--bg-card);
        }

        .history-item:hover {
            transform: scale(1.05);
            border-color: var(--accent-teal);
            box-shadow: 0 4px 12px rgba(56, 140, 129, 0.3);
        }

        .history-image-container {
            position: relative;
            aspect-ratio: 1;
        }

        .history-image-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .history-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(transparent, rgba(0,0,0,0.9));
            color: white;
            padding: 8px;
            font-size: 0.75rem;
            opacity: 0;
            transition: opacity 0.2s ease;
        }

        .history-item:hover .history-overlay {
            opacity: 1;
        }

        .history-prompt {
            display: -webkit-box;
            display: -moz-box;
            display: box;
            -webkit-line-clamp: 2;
            -moz-line-clamp: 2;
            line-clamp: 2;
            -webkit-box-orient: vertical;
            -moz-box-orient: vertical;
            box-orient: vertical;
            overflow: hidden;
            line-height: 1.3;
        }

        .delete-btn {
            position: absolute;
            top: 8px;
            right: 8px;
            background: rgba(220, 53, 69, 0.9);
            border: none;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            cursor: pointer;
            opacity: 0;
            transition: all 0.2s ease;
            font-size: 12px;
        }

        .history-item:hover .delete-btn {
            opacity: 1;
        }

        .delete-btn:hover {
            background: rgba(220, 53, 69, 1);
            transform: scale(1.1);
        }

        .form-range::-webkit-slider-thumb {
            background: var(--accent-teal);
        }

        .form-range::-moz-range-thumb {
            background: var(--accent-teal);
        }

        .range-value {
            background: var(--accent-teal);
            color: white;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 0.75rem;
            margin-left: 8px;
        }

        .history-grid img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 4px;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .history-grid img:hover {
            transform: scale(1.05);
            border: 1px solid var(--accent-primary);
        }
    </style>
</head>

<body class="has-navbar"
    x-data="{ ...imageGenerator(), ...userProfileApp(), prefix: window.APP_CONFIG?.appPrefix || '' }" x-init="init()"
    x-cloak>

    <div class="wrapper">
        <nav class="navbar navbar-expand-lg navbar-cyber">
            <div class="container-fluid">
                <a class="navbar-brand navbar-brand-cyber" :href="prefix + '/chat'">AI Character Chat</a>
                <button type="button" id="chat-sidebar-toggle" class="d-lg-none btn btn-outline-info me-2"
                    @click="sidebarActive = !sidebarActive">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi-list"
                        viewBox="0 0 16 16">
                        <path fill-rule="evenodd"
                            d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z" />
                    </svg>
                </button>
                <div class="navbar-collapse" id="navbarNav">
                    <div class="dropdown">
                        <div class="user-nav-summary dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown"
                            aria-expanded="false">
                            <div class="profile-avatar-sm"
                                x-text="user.display_name ? user.display_name[0].toUpperCase() : 'U'"></div>
                            <span>Chat Menu</span>
                        </div>

                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-cyber" aria-labelledby="userDropdown">
                            <li class="nav-item">
                                <a class="nav-link nav-link-cyber active" :href="prefix + '/chat'">Chat</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-cyber" :href="prefix + '/characters'">Characters</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-cyber" :href="prefix + '/image-gen'">Image Gen</a>
                            </li>
                            <li><a class="dropdown-item dropdown-item-cyber" :href="prefix + '/profile'">Profile Settings</a></li>
                            <li>
                                <hr class="dropdown-divider border-secondary">
                            </li>
                            <li><a class="dropdown-item dropdown-item-cyber text-danger" href="#"
                                    @click.prevent="logout()">Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <div class="container py-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="m-0">AI Image Generator</h3>
            </div>

            <div class="row">
                <!-- Sidebar Settings -->
                <div class="col-lg-5 mb-4">
                    <div class="image-settings-panel">
                        <div class="mb-3">
                            <label class="form-label text-cyan">AI Provider</label>
                            <div class="provider-selector">
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="provider" id="xai-provider" 
                                           value="xai" x-model="form.provider">
                                    <label class="btn btn-outline-info" for="xai-provider">
                                        <i class="bi bi-cpu"></i> X.AI Grok
                                    </label>
                                    
                                    <input type="radio" class="btn-check" name="provider" id="together-provider" 
                                           value="together" x-model="form.provider">
                                    <label class="btn btn-outline-success" for="together-provider">
                                        <i class="bi bi-lightning"></i> Together AI
                                    </label>
                                </div>
                            </div>
                            <small class="text-muted" x-show="currentProviderInfo">
                                Default: <span x-text="currentProviderInfo.currentDefault"></span>
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-cyan">Prompt</label>
                            <div class="prompt-container">
                                <textarea x-model="form.prompt" class="form-control" rows="5"
                                          placeholder="Describe the image you want to see..."
                                          @input="updatePromptPreview()"></textarea>
                                <div class="prompt-preview" x-show="form.prompt.length > 0">
                                    <small class="text-muted">Preview:</small>
                                    <div class="preview-text" x-text="form.prompt"></div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4 mb-2">
                                <div class="setting-card">
                                    <label class="form-label text-cyan small">Aspect Ratio</label>
                                    <select x-model="form.aspect_ratio" class="form-control form-control-sm">
                                        <option value="1:1">1:1</option>
                                        <option value="3:4">3:4</option>
                                        <option value="4:3">4:3</option>
                                        <option value="9:16">9:16</option>
                                        <option value="16:9">16:9</option>
                                        <option value="2:3">2:3</option>
                                        <option value="3:2">3:2</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4 mb-2">
                                <div class="setting-card">
                                    <label class="form-label text-cyan small">
                                        Steps <span class="range-value" x-text="form.steps"></span>
                                    </label>
                                    <input type="range" x-model="form.steps" class="form-range" min="1" max="50">
                                </div>
                            </div>
                            <div class="col-md-4 mb-2">
                                <div class="setting-card">
                                    <label class="form-label text-cyan small">
                                        Guidance <span class="range-value" x-text="form.guidance"></span>
                                    </label>
                                    <input type="range" x-model="form.guidance" class="form-range" min="1" max="20" step="0.5">
                                </div>
                            </div>
                        </div>

                        <button class="btn btn-cyber w-100 py-3 d-flex justify-content-center align-items-center gap-2"
                            @click="generateImage()" :disabled="loading || !form.prompt.trim()">
                            <span x-show="!loading">Generate Image</span>
                            <span x-show="loading">Generating...</span>
                            <div x-show="loading" class="spinner-border spinner-border-sm text-light" role="status">
                            </div>
                        </button>

                        <!-- Alert Message -->
                        <div x-show="message.text" class="alert mt-3 mb-0"
                            :class="message.type === 'error' ? 'alert-danger' : 'alert-success'" x-text="message.text"
                            style="display: none;"></div>
                    </div>
                </div>

                <!-- Result View -->
                <div class="col-lg-7">
                    <div class="image-preview-container">
                        <!-- Loading State -->
                        <div class="loading-overlay" x-show="loading" style="display: none;">
                            <div class="spinner-border text-info mb-3" style="width: 3rem; height: 3rem;" role="status">
                            </div>
                            <h5 class="text-info glow-text">Synthesizing image...</h5>
                            <p class="text-secondary small">This might take 10-20 seconds.</p>
                        </div>

                        <!-- Result Image -->
                        <template x-if="currentResult">
                            <div
                                class="text-center w-100 p-2 h-100 d-flex flex-column align-items-center justify-content-center">
                                <div class="mb-2">
                                    <span class="badge bg-info mb-2" x-text="'Provider: ' + (form.provider === 'xai' ? 'X.AI' : 'Together AI')"></span>
                                </div>
                                <img :src="currentResult.image_url" alt="Generated Image" class="shadow-lg mb-3">
                                <div class="d-flex gap-2">
                                    <a :href="currentResult.image_url" target="_blank"
                                        class="btn btn-sm btn-outline-info">
                                        Full Size
                                    </a>
                                    <button class="btn btn-sm btn-outline-secondary"
                                        @click="copyPrompt(currentResult.prompt)">
                                        Copy Prompt
                                    </button>
                                </div>
                            </div>
                        </template>

                        <!-- Empty State -->
                        <template x-if="!currentResult && !loading">
                            <div class="text-center text-secondary">
                                <i class="bi bi-image" style="font-size: 4rem; opacity: 0.5;"></i>
                                <p class="mt-2">Image will appear here</p>
                            </div>
                        </template>
                    </div>

                    <div class="mt-4" x-show="history.length > 0 && showHistory">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="d-flex align-items-center">
                                <h5 class="text-secondary mb-0 me-3">Recent Generations</h5>
                                <button class="btn btn-sm btn-outline-secondary" @click="showHistory = !showHistory">
                                    <i class="bi" :class="showHistory ? 'bi-chevron-up' : 'bi-chevron-down'"></i>
                                    <span x-text="showHistory ? 'Hide' : 'Show'"></span>
                                </button>
                            </div>
                            <button class="btn btn-sm btn-outline-danger" @click="clearHistory()">
                                <i class="bi bi-trash"></i> Clear All
                            </button>
                        </div>
                        <div class="history-grid-modern">
                            <template x-for="(item, index) in history" :key="index">
                                <div class="history-item" @click="viewHistoryItem(item)">
                                    <div class="history-image-container">
                                        <img :src="item.image_url" :alt="item.prompt">
                                        <div class="history-overlay">
                                            <span class="history-prompt" x-text="item.prompt"></span>
                                        </div>
                                    </div>
                                    <button class="delete-btn" @click.stop="deleteHistoryItem(item, index)">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            </template>
                        </div>
                    </div>

                    <!-- Show History Button (when hidden) -->
                    <div class="mt-4" x-show="history.length > 0 && !showHistory">
                        <div class="text-center">
                            <button class="btn btn-outline-secondary" @click="showHistory = true">
                                <i class="bi bi-images"></i>
                                Show Recent Generations (<span x-text="history.length"></span>)
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="public/app_userprofile.js?v=2"></script>
    <script src="public/app_image_gen.js?v=2"></script>
</body>

</html>