<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Character Chat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
    <script src="public/config.js"></script>
    <link rel="stylesheet" href="public/styles.css?v=18">
</head>

<body class="has-navbar" x-data="{ ...chatApp(), ...userProfileApp(), prefix: window.APP_CONFIG?.appPrefix || '' }"
    x-init="init()" x-cloak>

    <div class="wrapper chat-page">

        <div class="sidebar" id="chat-sidebar" :class="{ 'active': sidebarActive }">
            <div class="character-list">
                <p class="h5">Characters</p>
                <template x-for="char in characters" :key="char.id">
                    <div class="character-item" :class="{ 'active': currentCharacter?.id === char.id }"
                        @click="selectCharacter(char)">
                        <div class="d-flex align-items-center">
                            <template x-if="char.avatar">
                                <img :src="char.avatar"
                                    style="width:30px; height:30px; border-radius:50%; margin-right:10px; object-fit:cover;">
                            </template>
                            <template x-if="!char.avatar">
                                <div class="avatar-icon" x-text="char.name[0]"></div>
                            </template>
                            <div style="flex-grow:1; overflow:hidden;">
                                <span class="character-name" x-text="char.name"></span>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        </div>
        <!-- Mobile Sidebar Overlay -->
        <div class="sidebar-overlay" x-show="sidebarActive" x-transition.opacity @click="sidebarActive = false" x-cloak>
        </div>

        <div class="chat-container">

            <nav class="navbar navbar-expand-lg navbar-cyber">
                <div class="container-fluid">
                    <a class="navbar-brand navbar-brand-cyber" :href="prefix + '/chat'">AI Character Chat</a>
                    <button type="button" id="chat-sidebar-toggle" class="d-md-none btn btn-outline-info me-2"
                        @click="sidebarActive = !sidebarActive">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi-list"
                            viewBox="0 0 16 16">
                            <path fill-rule="evenodd"
                                d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z" />
                        </svg>
                    </button>
                    <div class="navbar-collapse" id="navbarNav">
                        <div class="dropdown">
                            <div class="user-nav-summary dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown"
                                aria-expanded="false">
                                <div class="profile-avatar-sm"
                                    x-text="user.display_name ? user.display_name[0].toUpperCase() : 'U'"></div>
                                <span>Menu</span>
                            </div>

                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-cyber" aria-labelledby="userDropdown">
                                <li class="nav-item">
                                    <a class="nav-link nav-link-cyber active" :href="prefix + '/chat'">Chat</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-cyber" :href="prefix + '/characters'">Characters</a>                            
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-cyber" :href="prefix + '/image-gen'">Image Gen</a>
                                </li>
                                <li><a class="dropdown-item dropdown-item-cyber" :href="prefix + '/profile'">Profile Settings</a></li>
                                <li>
                                    <hr class="dropdown-divider border-secondary">
                                </li>
                                <li><a class="dropdown-item dropdown-item-cyber text-danger" href="#"
                                        @click.prevent="logout()">Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="chat-header">

                <img x-show="currentCharacter?.avatar" :src="currentCharacter?.avatar ?? ''" id="character-avatar" />
                <div x-show="!currentCharacter?.avatar" class="avatar-icon"
                    x-text="currentCharacter?.name?.[0]?.toUpperCase() ?? '?'"></div>

                <div style="flex-grow:1;">
                    <p class="h5 m-0" x-text="currentCharacter ? currentCharacter.name : 'Select a character'"></p>
                </div>
                <button @click="clearHistory()" class="btn btn-sm btn-outline-danger" title="Clear History">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                        viewBox="0 0 16 16">
                        <path
                            d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z" />
                        <path
                            d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z" />
                    </svg>
                </button>
                <button @click="clearMemory()" class="btn btn-sm btn-outline-warning" title="Clear Memory">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                        viewBox="0 0 16 16">
                        <path d="M8 16s-1 0-1-1 1-4 5-4 5 3 4 5 4 1-1 1-1H8z"/>
                        <path d="M8 1A7 7 0 1 0 8 15a7 7 0 0 0 0-14zm0 1A6 6 0 1 1 8 15a6 6 0 0 1 0-12z"/>
                    </svg>
                </button>
            </div>

            <div id="chat-window" x-ref="chatWindow">
                <template x-for="(msg, index) in messages" :key="index">
                    <div class="message" :class="msg.role === 'user' ? 'user-message' : 'ai-message'">
                        <template x-if="msg.imageFilePath">
                            <div class="mb-2 chat-img">
                                <a :href="msg.imageFilePath" target="_blank">
                                    <img :src="msg.imageFilePath" style="max-width: 200px; max-height: 200px; cursor: pointer;">
                                </a>
                            </div>
                        </template>
                        <template x-if="msg.image && !msg.imageFilePath">
                            <div class="mb-2 chat-img"><img :src="msg.image"></div>
                        </template>
                        <div class="content" x-html="renderMarkdown(msg.content)"></div>
                    </div>
                </template>
                <div class="message ai-message" x-show="isTyping">
                    <template x-if="typingReasoning">
                        <details class="reasoning-details mb-2" open>
                            <summary class="text-muted small" style="cursor:pointer">Thinking...</summary>
                            <div class="content text-muted small mt-1"
                                style="border-left: 2px solid #555; padding-left: 8px;"
                                x-html="renderMarkdown(typingReasoning)"></div>
                        </details>
                    </template>
                    <div class="content" x-show="typingMessage" x-html="renderMarkdown(typingMessage)"></div>
                    <div class="typing-indicator" x-show="!typingMessage && !typingReasoning">
                        <div class="typing-dot"></div>
                        <div class="typing-dot"></div>
                        <div class="typing-dot"></div>
                    </div>
                </div>
            </div>

            <div x-show="selectedImage" id="image-preview-container" class="px-3 py-2"
                style="background: #16213e; border-top: 1px solid #0f3460;">
                <div class="position-relative d-inline-block">
                    <img id="image-preview" class="chat-img" :src="selectedImage">
                    <button @click="clearImage()"
                        class="btn btn-sm btn-danger position-absolute top-0 end-0 rounded-circle"
                        style="transform: translate(50%, -50%); padding: 0 6px;">&times;</button>
                </div>
            </div>

            <div class="chat-input-area">
                <div class="input-wrapper">
                    <label for="image-input" class="btn btn-link text-muted p-0 me-2 mb-0" style="cursor:pointer;">
                        <img src="public/icons/img.svg" alt="Image" width="24" height="24">
                        <input type="file" id="image-input" x-ref="imageInput" @change="handleImage" accept="image/*"
                            style="display:none;">
                    </label>
                    <textarea x-model="newMessage" class="message-input"
                        @keydown.enter.prevent="if(!$event.shiftKey && !$event.ctrlKey) sendMessage()"
                        placeholder="Type a message..." autocomplete="off" rows="1"
                        :style="`height: ${Math.min(newMessage.split('\n').length * 24 + 16, 200)}px`"></textarea>
                    <button class="send-button" @click="sendMessage()" :disabled="!currentCharacter || isTyping">
                        <img src="public/icons/send.svg" alt="Send" width="24" height="24">
                    </button>
                </div>
            </div>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dompurify/3.0.6/purify.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script src="public/app_userprofile.js?v=3"></script>
    <script src="public/app_chat.js?v=13"></script>
</body>

</html>