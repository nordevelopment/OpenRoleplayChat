<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - AI Character Chat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="public/config.js"></script>
    <link rel="stylesheet" href="public/styles.css?v=15">
</head>

<body>
    <div class="login-card" x-data="loginForm">
        <h4 class="text-center mb-4">Authorization</h4>
        <form @submit.prevent="submit">
            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <input type="email" x-model="email" class="form-control" required>
            </div>
            <div class="mb-4">
                <label class="form-label">Password</label>
                <input type="password" x-model="password" class="form-control" required>
            </div>
            <div x-show="errorMessage" x-text="errorMessage" class="text-danger small mb-3" style="display:none;"></div>
            <button type="submit" class="btn btn-cyber" :disabled="loading"
                x-text="loading ? 'Authenticating...' : 'Login'"></button>
        </form>
    </div>

    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="public/app_login.js?v=5"></script>
</body>

</html>