<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - AI Character Chat</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,100..900;1,100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Orbitron:wght@400..900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="/public/cybercore.css">
    <link rel="stylesheet" href="/public/styles.css?v=<%= version %>">
    
    <script src="/public/config.js"></script>
</head>

<body>
    <div class="login-container cyber-scanlines cyber-scanlines--scroll cyber-scanlines--fine">
        <div class="login-card" x-data="loginForm">
            <div class="cyber-text-center cyber-mb-md">
                <h1 class="cyber-heading" data-text="SYSTEM AUTH" style="font-size: var(--text-2xl);">SYSTEM AUTH</h1>
            </div>
            
            <form @submit.prevent="submit">
                <div class="cyber-field">
                    <label class="cyber-field__label">Identity (Email)</label>
                    <input type="email" x-model="email" class="cyber-input" required placeholder="admin@example.com" autocomplete="username">
                </div>
                
                <div class="cyber-field cyber-mb-md">
                    <label class="cyber-field__label">Passcode</label>
                    <input type="password" x-model="password" class="cyber-input" required placeholder="12345678" autocomplete="current-password">
                </div>
                
                <div x-show="errorMessage" x-text="errorMessage" class="cyber-alert cyber-alert--error cyber-mb-sm" style="display:none; padding: var(--space-xs) var(--space-sm) var(--space-xs) var(--space-lg); font-size: var(--text-sm);"></div>
                
                <button type="submit" class="cyber-btn cyber-btn--filled cyber-btn--magenta cyber-mt-sm" style="width: 100%; display: flex;" :disabled="loading">
                    <span x-text="loading ? 'ESTABLISHING LINK...' : 'INITIATE CONNECTION'"></span>
                </button>
            </form>
        </div>
    </div>

    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="public/app_login.js?v=<%= version %>"></script>
</body>

</html>